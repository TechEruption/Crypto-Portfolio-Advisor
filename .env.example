# Crypto Portfolio Advisor - Environment Variables

# ============== BLOCKCHAIN ==============
# Get from: https://www.alchemy.com/ or https://infura.io/
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Your wallet private key (DO NOT SHARE - use for deployment only)
PRIVATE_KEY=your_private_key_here

# Etherscan API Key for contract verification
ETHERSCAN_API_KEY=your_etherscan_api_key

# ============== API KEYS ==============
# Get from: https://openai.com/api/
OPENAI_API_KEY=sk-your_openai_key_here

# Get from: https://www.coingecko.com/api
COINGECKO_API_KEY=your_coingecko_api_key

# ============== BACKEND ==============
BACKEND_PORT=5000
BACKEND_URL=http://localhost:5000
NODE_ENV=development

# ============== FRONTEND ==============
NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_NETWORK=sepolia
NEXT_PUBLIC_CHAIN_ID=11155111

# ============== AI CONFIGURATION ==============
AI_MODEL=gpt-3.5-turbo
AI_TEMPERATURE=0.7
